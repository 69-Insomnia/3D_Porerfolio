# NPM Configuration
# Speeds up npm operations and improves security

# Use exact versions from package-lock.json
engine-strict=true

# Fail on missing peer dependencies
legacy-peer-deps=false

# Use CI-mode (faster, more reliable in CI/CD)
ci-mode=false

# Cache configuration
cache-max=Infinity
cache-min=10

# Allow running scripts
scripts-prepend-node-path=true
